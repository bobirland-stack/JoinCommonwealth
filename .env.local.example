# Curation workspace: Supabase connection (Stage A, Task 1).
#
# Copy this file to .env.local and fill in the two values from your Supabase
# project. .env.local is git-ignored, so your real values never get committed.
#
# Where these come from: in the Supabase dashboard, open your project, go to
# Project Settings, then API. Copy "Project URL" into the first line and the
# "anon public" key into the second.
#
# The anon key is meant to be public. It can do nothing on its own, because
# row-level security requires a signed-in project collaborator for every read
# and write.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Serverless endpoints (optional locally; set as repository Variables in
# production). Each is the URL of a small Cloudflare Worker. See
# serverless/README.md. Left empty, the matching flow tells you honestly that it
# is not connected rather than pretending it worked.
#
#   NEXT_PUBLIC_FLAG_ENDPOINT        opens a GitHub Issue for a flagged point
#   NEXT_PUBLIC_SUBMISSION_ENDPOINT  opens a GitHub Issue for a scout submission
#   NEXT_PUBLIC_PUBLISH_ENDPOINT     commits a reviewed meeting to clawson.json
#                                    and opens its pull request (Stage A, Task 3)
NEXT_PUBLIC_PUBLISH_ENDPOINT=
